---
import Header from '../components/ui/Header.astro';
import Footer from '../components/ui/Footer.astro';
import favicon from '@assets/images/1C_Company_logo.svg';
import Analytics from '../components/analytics/Analytics.astro';
import ScrollAnimations from '../components/scripts/ScrollAnimations.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  structuredData?: object;
  faqData?: Array<{ question: string; answer: string }>;
}

const { title, description, canonicalUrl, structuredData, faqData = [] } = Astro.props;
const siteUrl = 'https://resume.konopelko.com';
const fullCanonicalUrl =
  canonicalUrl && canonicalUrl.trim() !== ''
    ? siteUrl + canonicalUrl
    : siteUrl + Astro.url.pathname;
const fullOgImage = siteUrl + '/images/grigori-main.webp';

// Обновленный structuredData для программиста 1С
const jsonLdString = JSON.stringify(
  structuredData || {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Григорий Конопелько',
    jobTitle: 'Программист 1С и Front-end разработчик',
    description: description,
    url: siteUrl,
    telephone: '+7-921-751-0397',
    email: 'grigori.konopelko@mail.ru',
    address: {
      '@type': 'PostalAddress',
      addressCountry: 'RU',
      addressLocality: 'Санкт-Петербург',
    },
    areaServed: ['Россия'],
    knowsAbout: [
      '1С:Предприятие 8',
      'Управление торговлей (УТ)',
      'Управление холдингом (УХ)',
      'Бухгалтерия предприятия (БП)',
      'Зарплата и управление персоналом (ЗУП)',
      'Разработка на языке 1С',
      'Интеграция с внешними системами (HTTP, RabbitMQ, Kafka)',
    ],
    worksFor: {
      '@type': 'Organization',
      name: 'Самозанятый / Фриланс',
    },
  }
);

const faqStructuredData =
  faqData.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqData.map((q) => ({
          '@type': 'Question',
          name: q.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: q.answer.replace(/<[^>]*>/g, ''),
          },
        })),
      }
    : null;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="программист 1С, фронтенд разработчик, React, TypeScript, Санкт-Петербург, вакансии 1С, удаленная работа, 1С программист"
    />
    <link rel="canonical" href={fullCanonicalUrl} />

    <!-- Geo tags для локального SEO -->
    <meta name="geo.region" content="RU-SPE" />
    <meta name="geo.placename" content="Санкт-Петербург" />
    <meta name="geo.position" content="59.9342802;30.3350986" />
    <meta name="ICBM" content="59.9342802, 30.3350986" />

    <!-- Open Graph (для ссылок в соцсетях) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={fullCanonicalUrl} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content="Программист 1С - Григорий Конопелько" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="profile:first_name" content="Григорий" />
    <meta property="profile:last_name" content="Конопелько" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- Предварительное подключение для ускорения -->
    <link rel="preconnect" href="https://grigori.konopelko.com" />
    <link rel="dns-prefetch" href="https://grigori.konopelko.com" />

    <!-- Аналитика -->
    <Analytics />

    <meta name="yandex-verification" content="7cd2bf4f92125340" />
    <link rel="icon" href={favicon.src} type="image/svg+xml" />

    <!-- Предзагрузка главного изображения -->
    <link rel="preload" as="image" href="/images/grigori.webp" fetchpriority="high" />

    <!-- Структурированные данные -->
    <script is:inline type="application/ld+json" set:html={jsonLdString} />

    {
      faqStructuredData && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
      )
    }

    <!-- Критический CSS -->
    <style>
      .body-wrapper {
        background: var(--background-white);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        margin: 0 auto;
        padding: 0 2rem;
        width: 100%;
        max-width: 75rem;
      }

      .main-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        width: 100%;
        gap: 1rem;
      }

      .hero h1 {
        opacity: 1;
        font-family: var(--font-heading);
        font-size: var(--heading-1);
        font-weight: 700;
      }

      .teacher-photo {
        opacity: 1;
        border-radius: 50%;
        object-fit: cover;
        width: 400px;
        height: 400px;
      }

      h1,
      h2,
      h3 {
        font-family: var(--font-heading);
        color: var(--text-primary);
        font-weight: 600;
        line-height: 1.3;
        text-align: center;
        margin: 0.5em 0;
      }

      @media (max-width: 48rem) {
        .body-wrapper {
          padding: 0 1rem;
        }
        .main-container {
          gap: 0.5rem;
        }
        .teacher-photo {
          width: 300px;
          height: 300px;
        }
      }

      @media (max-width: 26.875rem) {
        .body-wrapper {
          padding: 0 0.5rem;
        }
      }

      @media (max-width: 23.4375rem) {
        .body-wrapper {
          padding: 0 0.25rem;
        }
        .teacher-photo {
          width: 250px;
          height: 250px;
        }
      }
    </style>
  </head>
  <body>
    <div class="body-wrapper">
      <Header />
      <main class="main-container">
        <slot />
      </main>
      <Footer />
    </div>
    <ScrollAnimations />
  </body>
</html>
